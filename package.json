{
  "name": "gen-con-buddy",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
    "preview": "vite preview",
    "lint": "oxlint --ignore-path .oxlintignore -c .oxlintrc.json . && eslint . && npm run lint:css",
    "lint:css": "stylelint '**/*.css' --ignore-path .gitignore",
    "test": "NODE_OPTIONS='--max-old-space-size=8192 --expose-gc' vitest run",
    "test:watch": "vitest",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@date-fns/tz": "^1.4.1",
    "@tanstack/react-query": "^5.74.4",
    "@tanstack/react-router": "^1.114.0",
    "@tanstack/react-table": "^8.21.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.14.0",
    "posthog-js": "^1.372.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.55.0"
  },
  "devDependencies": {
    "@storybook/react-vite": "^10.3.5",
    "@tanstack/router-plugin": "^1.114.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "msw": "^2.7.3",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "storybook": "^10.3.5",
    "stylelint": "^17.9.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
