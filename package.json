{
  "name": "gen-con-buddy",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "concurrently -n api,web -c cyan,green \"sh -c 'cd ../Gen-Con-Buddy-API && set -a && source .env && ./bin/gcb api'\" \"vite\"",
    "start:prod": "VITE_API_URL=https://web-production-e0d43.up.railway.app vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
    "preview": "vite preview",
    "lint": "oxlint --ignore-path .oxlintignore -c .oxlintrc.json . && eslint . && npm run lint:css",
    "lint:css": "stylelint '**/*.css' --ignore-path .gitignore",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@tanstack/react-query": "^5.74.4",
    "@tanstack/react-router": "^1.114.0",
    "@tanstack/react-table": "^8.21.3",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.55.0"
  },
  "devDependencies": {
    "@storybook/react-vite": "^10.3.5",
    "@tanstack/router-plugin": "^1.114.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "msw": "^2.7.3",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.60.0",
    "storybook": "^10.3.5",
    "stylelint": "^17.9.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.14",
    "vitest": "^2.1.9"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
